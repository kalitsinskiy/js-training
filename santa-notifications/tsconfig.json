{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext", //"commonjs"
    "strict": true,
    "esModuleInterop": true,
    //"ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "nodenext", //"node"
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
